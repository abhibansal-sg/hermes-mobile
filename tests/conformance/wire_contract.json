      "steer": {
        "kind": "request",
        "$comment": "Protocol §5 (QA-2 R11): live-turn steering over the relay. The phone sends session_id + text; the relay passes them to the gateway's session.steer, which returns {status: queued|rejected, text} — passed through verbatim so the phone maps the disposition identically to the gateway-direct path. Before this method existed the phone's steer went over the IDLE gateway-direct socket in relay mode and every attempt failed with 'Not connected'.",
        "ios_sends": {
          "required": [
            "session_id",
            "text"
          ],
          "optional": []
