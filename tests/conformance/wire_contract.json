{
  "$comment": "SINGLE SOURCE OF TRUTH for the Hermes mobile relay wire contract (docs/RELAY-PHONE-PROTOCOL.md). Consumed key-for-key by BOTH the pytest side (tests/conformance/test_*.py, which also re-extracts the real surface from the Swift + Python sources and fails on ANY drift) and the XCTest side (apps/ios/HermesMobileTests/WireConformanceTests.swift, bundled via project.yml). A2/N1 of docs/DAILY-DRIVER-SPEC.md: the prompt/text, decision/choice, text/answer bug class is structurally impossible when this file, the Swift sources, and the relay sources all agree.",
  "version": 1,
  "upstream": {
    "envelope": {
      "request": ["jsonrpc", "id", "method", "params"],
      "notification": ["jsonrpc", "method", "params"]
    },
    "notifications": ["ack", "resync", "foreground"],
    "payloads": {
      "submit": {
        "kind": "request",
        "ios_sends": {
          "required": ["prompt"],
          "optional": ["session_id", "client_message_id"]
        },
        "relay_reads": {
          "required": [],
          "optional": ["prompt", "text", "session_id", "client_message_id", "title", "model", "provider"]
        },
        "aliases": [["prompt", "text"]],
        "example": {
          "prompt": "Hello from the phone",
          "session_id": "sess-1",
          "client_message_id": "cmid-1"
        },
        "expect_gateway": [
          {"rpc": "session.resume", "params_include": {"session_id": "sess-1"}},
          {"rpc": "prompt.submit", "params": {"session_id": "sess-1", "text": "Hello from the phone"}}
        ]
      },
      "resume": {
        "kind": "request",
        "ios_sends": {"required": ["session_id"], "optional": []},
        "relay_reads": {"required": ["session_id"], "optional": []},
        "aliases": [],
        "example": {"session_id": "sess-1"},
        "expect_gateway": [
          {"rpc": "session.resume", "params_include": {"session_id": "sess-1"}}
        ]
      },
      "open": {
        "kind": "request",
        "ios_sends": {"required": ["session_id"], "optional": []},
        "relay_reads": {"required": ["session_id"], "optional": []},
        "aliases": [],
        "example": {"session_id": "sess-1"},
        "expect_gateway": [
          {"rpc": "rest_history", "params_include": {"session_id": "sess-1"}}
        ]
      },
      "list": {
        "kind": "request",
        "ios_sends": {"required": [], "optional": []},
        "relay_reads": {"required": [], "optional": ["limit"]},
        "aliases": [],
        "example": {},
        "expect_gateway": [
          {"rpc": "session.list", "params_include": {}}
        ]
      },
      "history": {
        "kind": "request",
        "ios_sends": {"required": ["session_id"], "optional": ["limit"]},
        "relay_reads": {"required": ["session_id"], "optional": ["limit"]},
        "aliases": [],
        "example": {"session_id": "sess-1", "limit": 50},
        "expect_gateway": [
          {"rpc": "rest_history", "params_include": {"session_id": "sess-1"}}
        ],
        "expect_result": {"messages_tail": 50}
      },
      "approve": {
        "kind": "request",
        "$comment": "Protocol §5: the phone sends session_id + decision (once/session/always/deny/approve); the relay maps decision -> the gateway's `choice` param. Sending `approved`/omitting session_id here is the silent-DENY bug class — the relay reads p[\"session_id\"] and p[\"decision\"].",
        "ios_sends": {
          "required": ["session_id", "decision"],
          "optional": ["request_id", "all"]
        },
        "relay_reads": {
          "required": ["session_id", "decision"],
          "optional": ["request_id", "all"]
        },
        "aliases": [],
        "example": {
          "session_id": "sess-1",
          "request_id": "req-1",
          "decision": "approve"
        },
        "expect_gateway": [
          {
            "rpc": "approval.respond",
            "params": {
              "session_id": "sess-1",
              "request_id": "req-1",
              "choice": "approve",
              "all": false
            }
          }
        ]
      },
      "clarify": {
        "kind": "request",
        "$comment": "Protocol §5: the phone sends session_id + text; the relay maps text -> the gateway's `answer` param (the gateway stores params[\"answer\"], matched by request_id). Sending `response`/omitting text is the EMPTY-ANSWER bug class.",
        "ios_sends": {
          "required": ["session_id", "text"],
          "optional": ["request_id"]
        },
        "relay_reads": {
          "required": ["session_id", "text"],
          "optional": ["request_id"]
        },
        "aliases": [],
        "example": {
          "session_id": "sess-1",
          "request_id": "clr-1",
          "text": "staging"
        },
        "expect_gateway": [
          {
            "rpc": "clarify.respond",
            "params": {
              "session_id": "sess-1",
              "request_id": "clr-1",
              "answer": "staging"
            }
          }
        ]
      },
      "interrupt": {
        "kind": "request",
        "ios_sends": {"required": ["session_id"], "optional": []},
        "relay_reads": {"required": ["session_id"], "optional": []},
        "aliases": [],
        "example": {"session_id": "sess-1"},
        "expect_gateway": [
          {"rpc": "session.interrupt", "params_include": {"session_id": "sess-1"}}
        ]
      },
      "ack": {
        "kind": "notification",
        "ios_sends": {"required": ["through"], "optional": []},
        "relay_reads": {"required": [], "optional": ["through"]},
        "aliases": [],
        "example": {"through": 7},
        "expect_gateway": []
      },
      "resync": {
        "kind": "notification",
        "ios_sends": {"required": ["last_seq"], "optional": []},
        "relay_reads": {"required": [], "optional": ["last_seq"]},
        "aliases": [],
        "example": {"last_seq": 0},
        "expect_gateway": []
      },
      "foreground": {
        "kind": "notification",
        "$comment": "session_id is REQUIRED as a key but its VALUE is nullable (null clears the foreground set, §6).",
        "ios_sends": {"required": ["session_id"], "optional": [], "nullable": ["session_id"]},
        "relay_reads": {"required": [], "optional": ["session_id"]},
        "aliases": [],
        "example": {"session_id": "sess-1"},
        "expect_gateway": []
      }
    }
  },
  "downstream": {
    "envelope": ["seq", "sid", "turn", "kind", "body"],
    "envelope_optional": ["turn"],
    "kinds": [
      "item.started",
      "item.delta",
      "item.completed",
      "turn.started",
      "turn.completed",
      "approval.request",
      "clarify.request",
      "status",
      "title",
      "snapshot"
    ],
    "item_shape": {
      "required": ["item_id", "type"],
      "optional": ["status", "ord", "summary", "body"]
    },
    "item_statuses": ["in_progress", "completed", "failed"],
    "item_types": {
      "$comment": "relay_all = relay ItemType.ALL (the types the reframer can emit). ios_native = ChatItemType raw values (decoded natively). generic_fold = relay types iOS intentionally folds to the generic toolCall card (§2 forward-compat rule). When a fold entry gains a native iOS case (e.g. N4 taskList), move it to ios_native and drop it here — the suite fails until the fixture matches the sources either way.",
      "relay_all": [
        "userMessage",
        "agentMessage",
        "reasoning",
        "toolCall",
        "taskList",
        "fileChange",
        "image",
        "browser",
        "error",
        "usage"
      ],
      "ios_native": [
        "userMessage",
        "agentMessage",
        "reasoning",
        "toolCall",
        "taskList",
        "fileChange",
        "image",
        "browser",
        "error",
        "usage"
      ],
      "generic_fold": []
    },
    "body_contract": {
      "item.started": {"item_frame": true},
      "item.completed": {"item_frame": true},
      "item.delta": {"required": ["item_id"], "optional": ["patch"], "closed": true},
      "turn.started": {"required": [], "optional": [], "closed": true},
      "turn.completed": {"required": [], "optional": ["usage"], "closed": true},
      "approval.request": {
        "passthrough": true,
        "guaranteed": ["command", "description"],
        "reply_rpc": "approve",
        "reply_identity": "envelope.sid",
        "ios_reads": ["approval_id", "id", "request_id", "command", "pattern_key", "description", "action", "target", "title", "approval_title"]
      },
      "clarify.request": {
        "passthrough": true,
        "guaranteed": ["request_id", "question", "choices"],
        "reply_rpc": "clarify",
        "reply_identity": "body.request_id",
        "ios_reads": ["question", "choices", "request_id"]
      },
      "status": {"required": ["kind", "text"], "optional": [], "closed": true},
      "title": {"required": ["title"], "optional": [], "closed": true},
      "snapshot": {"required": ["items"], "optional": ["cursor"], "closed": true}
    },
    "samples": [
      {
        "name": "item.started.agentMessage",
        "frame": {
          "seq": 1,
          "sid": "sess-1",
          "turn": "sess-1:t1",
          "kind": "item.started",
          "body": {
            "item_id": "sess-1:i1",
            "type": "agentMessage",
            "status": "in_progress",
            "ord": 0,
            "summary": "",
            "body": {"text": ""}
          }
        }
      },
      {
        "name": "item.delta.text",
        "frame": {
          "seq": 2,
          "sid": "sess-1",
          "turn": "sess-1:t1",
          "kind": "item.delta",
          "body": {"item_id": "sess-1:i1", "patch": {"text": "Hello"}}
        }
      },
      {
        "name": "item.completed.agentMessage",
        "frame": {
          "seq": 3,
          "sid": "sess-1",
          "turn": "sess-1:t1",
          "kind": "item.completed",
          "body": {
            "item_id": "sess-1:i1",
            "type": "agentMessage",
            "status": "completed",
            "ord": 0,
            "summary": "Hello there",
            "body": {"text": "Hello there"}
          }
        }
      },
      {
        "name": "item.completed.taskList.native",
        "$comment": "taskList is emitted by the relay and decoded natively since N4 (ChatItemType.taskList → TaskListItemView/dock bridge). generic_fold is now empty; the §2 forward-compat rule (unknown type → toolCall card) still holds for future relay types. XCTest asserts the fold matches item_types.generic_fold.",
        "frame": {
          "seq": 4,
          "sid": "sess-1",
          "turn": "sess-1:t1",
          "kind": "item.completed",
          "body": {
            "item_id": "sess-1:tasks",
            "type": "taskList",
            "status": "completed",
            "ord": 1,
            "summary": "Tasks 2/2",
            "body": {
              "tasks": [
                {"id": "t1", "text": "First", "status": "completed"},
                {"id": "t2", "text": "Second", "status": "completed"}
              ],
              "counts": {"total": 2, "pending": 0, "in_progress": 0, "completed": 2, "cancelled": 0},
              "all_complete": true
            }
          }
        }
      },
      {
        "name": "item.completed.usage",
        "frame": {
          "seq": 5,
          "sid": "sess-1",
          "turn": "sess-1:t1",
          "kind": "item.completed",
          "body": {
            "item_id": "sess-1:i2",
