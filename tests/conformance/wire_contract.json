      },
      {
        "name": "turn.started",
        "frame": {"seq": 6, "sid": "sess-1", "turn": "sess-1:t1", "kind": "turn.started", "body": {}}
      },
      {
        "name": "turn.completed.usage",
        "frame": {
          "seq": 7,
          "sid": "sess-1",
          "turn": "sess-1:t1",
          "kind": "turn.completed",
          "body": {"usage": {"input": 10, "output": 5, "total": 15}}
        }
      },
      {
        "name": "approval.request",
        "frame": {
          "seq": 8,
          "sid": "sess-1",
          "turn": "sess-1:t1",
