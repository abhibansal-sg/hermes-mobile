      },
      {
        "name": "status.heartbeat.connectionScoped",
        "$comment": "Connection-scoped frame: `turn` legitimately absent-but-null (iOS decodes it optional).",
        "frame": {
          "seq": 13,
          "sid": "",
          "turn": null,
          "kind": "status",
          "body": {"kind": "heartbeat", "text": ""}
        }
      }
    ]
  },
  "gateway": {
    "$comment": "The relay -> gateway edge (gateway_client.py senders vs tui_gateway/server.py readers). Ground truth is the in-repo gateway source. This edge is where decision/choice and text/answer mismatches silently broke approvals and clarify answers.",
    "rpcs": {
      "prompt.submit": {
        "relay_sends": {"required": ["session_id", "text"], "optional": []},
        "gateway_reads": {"required": [], "optional": ["session_id", "text", "truncate_before_user_ordinal"]}
      },
      "approval.respond": {
        "$comment": "The gateway defaults choice to DENY when absent — a relay that sends `decision` instead of `choice` silently denies every approval. request_id is a declared forward-compat extra: the gateway resolves approvals by SESSION key and ignores it (gateway_client.py keeps it for logging); it must never be an effective key.",
        "relay_sends": {"required": ["session_id", "request_id", "choice", "all"], "optional": []},
        "gateway_reads": {"required": [], "optional": ["session_id", "choice", "all"], "defaults": {"choice": "deny", "all": false}},
        "accepted_unread": ["request_id"]
      },
      "clarify.respond": {
        "$comment": "The gateway matches the pending waiter by request_id and stores params[\"answer\"] — a relay that sends `text` delivers an EMPTY answer. session_id is a declared symmetry extra: the gateway resolves clarify by request_id only.",
        "relay_sends": {"required": ["session_id", "request_id", "answer"], "optional": []},
        "gateway_reads": {"required": [], "optional": ["request_id", "answer"]},
        "accepted_unread": ["session_id"]
      },
      "session.list": {
        "relay_sends": {"required": ["limit"], "optional": []},
        "gateway_reads": {"required": [], "optional": ["limit"]}
      },
      "session.create": {
        "relay_sends": {"required": ["title", "cols", "source"], "optional": ["model", "provider"]},
        "gateway_reads": {"required": [], "optional": ["close_on_disconnect", "cols", "cwd", "fast", "messages", "model", "parent_session_id", "profile", "provider", "reasoning_effort", "source", "title"]}
      },
      "session.resume": {
        "relay_sends": {"required": ["session_id", "cols", "source"], "optional": []},
        "gateway_reads": {"required": [], "optional": ["close_on_disconnect", "cols", "eager_build", "lazy", "profile", "session_id", "source"]}
      },
      "session.interrupt": {
        "relay_sends": {"required": ["session_id"], "optional": []},
        "gateway_reads": {"required": [], "optional": ["session_id"]}
      }
    }
  }
}
