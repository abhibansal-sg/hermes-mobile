          }
        }
      },
      {
        "name": "status.thinking",
        "frame": {
          "seq": 10,
          "sid": "sess-1",
          "turn": "sess-1:t1",
          "kind": "status",
          "body": {"kind": "thinking", "text": "Formulating…"}
        }
      },
      {
        "name": "title",
        "frame": {"seq": 11, "sid": "sess-1", "turn": null, "kind": "title", "body": {"title": "Release planning"}}
      },
      {
