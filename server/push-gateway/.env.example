# Production refuses SQLite, automatic schema creation, APNs-disabled mode,
# and every development App Attest fallback.
HPG_PRODUCTION=true
HPG_DATABASE_URL=postgresql+psycopg://push_gateway:change-me@push-gateway-db:5432/push_gateway
HPG_AUTO_CREATE_SCHEMA=false

# Generate these independently: openssl rand -base64 32
# Legacy single-key form (still supported). For a rotation, remove this line
# and use exactly one of HPG_TOKEN_MASTER_KEYS_FILE / ..._JSON below.
HPG_TOKEN_MASTER_KEY_B64=replace-with-base64-of-32-random-bytes
HPG_CAPABILITY_PEPPER_B64=replace-with-different-base64-of-32-random-bytes
HPG_TOKEN_KEY_VERSION=1
# HPG_TOKEN_MASTER_KEYS_FILE=/run/secrets/push-token-keyring.json
# HPG_TOKEN_MASTER_KEYS_JSON={"1":"old-base64-key","2":"new-base64-key"}

HPG_ALLOWED_BUNDLE_IDS=ai.hermes.app
HPG_APPLE_APP_ID=TEAMID.ai.hermes.app
HPG_APP_ATTEST_PRODUCTION=true
HPG_APNS_KEY_PATH=/run/secrets/apns_key
HPG_APNS_KEY_ID=XXXXXXXXXX
HPG_APNS_TEAM_ID=XXXXXXXXXX

# Ed25519 seed used only when this Gateway may activate official Hub routes.
# Its matching public key must be HRH_ACTIVATION_PUBLIC_KEY_B64 on the Hub.
# HPG_HUB_ACTIVATION_PRIVATE_KEY_B64=replace-with-base64-of-32-byte-seed
# Rotation form (mutually exclusive with the legacy seed):
# HPG_HUB_ACTIVATION_PRIVATE_KEYS_FILE=/run/secrets/hub-activation-keyring.json
# HPG_HUB_ACTIVATION_KEY_ID=2026-07

HPG_CHALLENGE_TTL_SECONDS=300
HPG_CHALLENGE_PER_SOURCE_PER_HOUR=60
HPG_MAXIMUM_LIVE_CHALLENGES=10000
HPG_ATTESTATION_MAX_CONCURRENCY=4
HPG_DATABASE_MAX_CONCURRENCY=8
HPG_BIND_TOKEN_TTL_SECONDS=600
HPG_RESPONSE_RECEIPT_TTL_SECONDS=86400
HPG_MAX_SENDS_PER_HOUR=120
HPG_MAX_SENDS_PER_DAY=1000
HPG_SEND_RETRY_BASE_SECONDS=2
HPG_SEND_RETRY_MAX_SECONDS=60

# The combined Compose sets this to its fixed Caddy IP. For a custom proxy,
# trust only its exact IP/CIDR; never use "*".
# HPG_FORWARDED_ALLOW_IPS=172.31.251.2
