# Production refuses SQLite, automatic schema creation, and development activation.
HRH_PRODUCTION=true
HRH_DATABASE_URL=postgresql+psycopg://relay_hub:change-me@relay-hub-db:5432/relay_hub
HRH_AUTO_CREATE_SCHEMA=false

# Configure at least one authority. Operator enrollment is suitable for a
# self-hosted deployment. Official deployments use the Push Gateway's Ed25519
# public key to verify short-lived App-Attested activation tokens.
# HRH_OPERATOR_ENROLLMENT_TOKEN=<secret-manager-value>
# HRH_ACTIVATION_PUBLIC_KEY_B64=replace-with-base64-of-32-byte-public-key

HRH_PROVISIONAL_TTL_SECONDS=600
HRH_MAXIMUM_RETENTION_SECONDS=86400
HRH_REQUEST_CLOCK_SKEW_SECONDS=300
HRH_PROVISIONAL_PER_SOURCE_PER_HOUR=20
HRH_MAXIMUM_LIVE_PROVISIONAL_ROUTES=10000
HRH_MAXIMUM_LIVE_PAIR_OFFERS_PER_ROUTE=8
HRH_PAIR_CONFIRMATION_RECEIPT_TTL_SECONDS=86400
HRH_RECEIPT_RECORDS_PER_ROUTE=4096
HRH_RECEIPT_RESERVED_RECORDS=64
HRH_ACCEPTED_MESSAGES_PER_ROUTE_PER_MINUTE=600
HRH_ACCEPTED_MESSAGE_RATE_RESERVE=60
HRH_MAXIMUM_REQUEST_BODY_BYTES=400000
HRH_SOCKET_QUEUE_DEPTH=512

# The combined Compose sets Uvicorn's generic FORWARDED_ALLOW_IPS to its fixed
# Caddy IP. For a custom proxy, trust only its exact IP/CIDR; never use "*".
# FORWARDED_ALLOW_IPS=172.31.250.2
